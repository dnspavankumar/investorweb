rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /founders/{founderId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == founderId;
    }

    match /investors/{investorId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == investorId;
    }
  }
}
